# Required
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PI_RPC_KEY=RESTRICTED_RPC_EXECUTE_KEY
KIOSK_ID=KIOSK-001

# Sensor wiring and behavior
DOOR_SENSOR_ID=door-1
DOOR_SENSOR_PIN=22
DOOR_SENSOR_OPEN_STATE=HIGH
DOOR_SENSOR_PULL=UP
DOOR_SENSOR_BOUNCE_SECONDS=0.08

# Queue and sender tuning
DOOR_QUEUE_DB_PATH=/var/lib/inventory-door/telemetry-queue.db
DOOR_QUEUE_BATCH_SIZE=40
DOOR_QUEUE_FLUSH_SECONDS=0.6
DOOR_QUEUE_RETENTION_DAYS=7
DOOR_HEARTBEAT_SECONDS=60

# Optional unlock context handoff
DOOR_UNLOCK_CONTEXT_FILE=/var/lib/inventory-door/unlock-context.json
DOOR_UNLOCK_CONTEXT_WINDOW_SECONDS=30
